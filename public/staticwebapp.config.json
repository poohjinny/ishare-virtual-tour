{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.{css,js,webp,svg,png,jpg,jpeg,ico,woff2,json,html,txt}"
    ]
  },
  "routes": [
    {
      "route": "/assets/*",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    }
  ],
  "globalHeaders": { "X-Content-Type-Options": "nosniff" }
}
